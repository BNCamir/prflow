# Database (Neon or Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Auth (dashboard login)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Cron (Vercel Cron calls daily-check with this header)
CRON_SECRET=generate-a-random-secret

# Encrypt SproutGigs credentials at rest (32 bytes base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Use real SproutGigs client (when implemented)
# SPROUTGIGS_USE_REAL_CLIENT=false
